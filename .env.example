# SwasthSetu AI environment
# Copy this file to .env.local for local development.
# In Vercel/Render/Netlify, add the same values in Environment Variables.

# REQUIRED: Supabase Auth + Database
# Get these from Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# Optional: Google Cloud / Vertex / Translate integrations
GOOGLE_CLOUD_PROJECT=
VERTEX_AI_LOCATION=asia-south1
GOOGLE_TRANSLATE_API_KEY=

# Optional future Firebase adapter values
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
